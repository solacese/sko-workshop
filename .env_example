# Solace broker — "solace" is the container name on sam-network
SOLACE_DEV_MODE="false"
SOLACE_BROKER_URL="ws://solace:8008"
SOLACE_BROKER_VPN="default"
SOLACE_BROKER_USERNAME="default"
SOLACE_BROKER_PASSWORD="default"

# LLM — LiteLLM proxy at mymaas.net
LLM_SERVICE_ENDPOINT="https://lite-llm.mymaas.net/"
LLM_SERVICE_API_KEY=<INSERT_HERE>
LLM_SERVICE_GENERAL_MODEL_NAME="openai/claude-sonnet-4-6"
LLM_SERVICE_PLANNING_MODEL_NAME="openai/claude-sonnet-4-6"

# SAM data directory (matches volume mount in docker-compose.yaml)
SAM_DATA_DIR="/tmp/sam-data"
SAM_TOOLS_DIR=/opt/sam/builtin-tools

# Feature flag
SAM_FEATURE_PROJECT_SHARING="true"
SAM_FEATURE_BUILDER="true"
SAM_FEATURE_OFFLINE_EVALS="true"
SAM_FEATURE_ARTIFACT_ATTACHMENT="true"
SAM_FEATURE_REMOTE_TOOL_EXECUTION="true"
SAM_FEATURE_NEW_NAVIGATION="true"
SAM_FEATURE_EMAIL_GATEWAY="true"
SAM_FEATURE_EVENT_MESH_CONNECTOR="true"
SAM_FEATURE_SLACK_CONNECTOR="true"
